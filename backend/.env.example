PORT=3000
DATABASE_PATH=./database/door-lock.sqlite

# REST API security
# When API_KEY is set, every /api route except /api/health requires this key.
API_KEY=dev-secret-key

# MQTT broker
MQTT_URL=mqtt://localhost:1883
MQTT_CLIENT_ID=door-lock-api
MQTT_COMMAND_TOPIC_PREFIX=doorlock/device
MQTT_STATUS_TOPIC=doorlock/device/+/status
# Smart-home nodes can reuse the same command payload shape:
# doorlock/device/{deviceId}/command
# Suggested device IDs: socket_light_001, socket_fan_001, socket_tv_001, elevator_001, env_node_001
MQTT_USERNAME=doorlock_backend
MQTT_PASSWORD=strong_password
MQTT_RECONNECT_MS=5000

# WebSocket
WS_PATH=/ws
WS_HEARTBEAT_MS=30000
